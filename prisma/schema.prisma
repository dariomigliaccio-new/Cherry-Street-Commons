generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("text")
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id      String  @id @default(cuid())
  label   String
  href    String
  order   Int     @default(0)
  visible Boolean @default(true)
}

model Banner {
  id         String  @id @default(cuid())
  title      String
  subtitle   String  @default("")
  buttonText String  @default("")
  buttonHref String  @default("")
  imageUrl   String  @default("")
  order      Int     @default(0)
  active     Boolean @default(true)
}

model Section {
  id       String  @id @default(cuid())
  slug     String  @unique
  title    String
  content  String
  imageUrl String  @default("")
  order    Int     @default(0)
  visible  Boolean @default(true)
}

model FloorPlan {
  id          String  @id @default(cuid())
  name        String
  bedrooms    Int     @default(1)
  bathrooms   Float   @default(1)
  sqft        Int     @default(0)
  units       Int     @default(1)
  description String  @default("")
  imageUrl    String  @default("")
  order       Int     @default(0)
  available   Boolean @default(true)
}

model QualificationLead {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String
  phone          String   @default("")
  householdSize  Int      @default(1)
  annualIncome   Int      @default(0)
  hasVoucher     Boolean  @default(false)
  unitType       String   @default("")
  message        String   @default("")
  createdAt      DateTime @default(now())
  contacted      Boolean  @default(false)
}
